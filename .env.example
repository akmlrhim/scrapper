# =============================================
# GeoLeads - Environment Variables
# Salin file ini ke .env dan isi nilainya
# =============================================

# Supabase (Frontend + Backend)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase (Backend only - Service Role Key)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SerpAPI - Google Maps scraping (RECOMMENDED, gratis 100 searches/bulan, tanpa kartu kredit)
# Daftar di: https://serpapi.com/users/sign_up
SERPAPI_KEY=

# Google Places API (alternatif, butuh billing Google)
# Dapatkan di: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
